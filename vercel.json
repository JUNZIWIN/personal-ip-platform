{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "aiipower.me" }
      ],
      "destination": "/bowen.html"
    },
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "www.aiipower.me" }
      ],
      "destination": "/bowen.html"
    },
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "bowentian.aiipower.me" }
      ],
      "destination": "/bowen.html"
    },
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "bowentian.com" }
      ],
      "destination": "/bowen.html"
    },
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "www.bowentian.com" }
      ],
      "destination": "/bowen.html"
    },
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "bizatom.ai" }
      ],
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/bowen.html",
      "has": [
        { "type": "host", "value": "aiipower.me" }
      ],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/bowen.html",
      "has": [
        { "type": "host", "value": "www.aiipower.me" }
      ],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/bowen.html",
      "has": [
        { "type": "host", "value": "bowentian.aiipower.me" }
      ],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/bowen.html",
      "has": [
        { "type": "host", "value": "bowentian.com" }
      ],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/bowen.html",
      "has": [
        { "type": "host", "value": "www.bowentian.com" }
      ],
      "destination": "/",
      "permanent": true
    }
  ]
}
